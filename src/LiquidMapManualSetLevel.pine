//@version=5
indicator("Hola Mundo - Ray a 0.10% encima del precio", overlay=true)

// ==================================================================
// Descripción:
// Este script dibuja un rayo horizontal (línea extendida a la derecha)
// que se ubica constantemente a 0.10% por encima del precio de cierre
// actual. Además colocamos una etiqueta con el texto "Hola Mundo"
// justo en esa posición para que sea visible en el gráfico.
// ==================================================================

// Parámetros configurables por el usuario
offsetPct = input.float(0.10, title="Offset (%) encima del precio", step=0.01)
useClosePrice = input.bool(true, title="Usar precio de cierre (si no, usa precio actual)")

// Convertimos el porcentaje a factor multiplicador: 0.10% -> 0.001
offsetFactor = offsetPct / 100.0

// Precio de referencia: por defecto el cierre, pero puede ajustarse
priceRef = useClosePrice ? close : close // en Pine v5 no hay price 'last' distinto en script, usar close

// Nivel objetivo = precioRef * (1 + offsetFactor)
targetLevel = priceRef * (1 + offsetFactor)

// Creamos/actualizamos una línea tipo rayo (extend.right) que se mueve con targetLevel
var line rayLine = na
if na(rayLine)
    // Crear la línea en el primer bar válido: desde la barra actual hacia la derecha
    rayLine := line.new(x1=bar_index, y1=targetLevel, x2=bar_index+1, y2=targetLevel, xloc=xloc.bar_index, extend=extend.right, color=color.yellow, width=2)
else
    // Actualizar la posición Y de la línea para seguir targetLevel
    line.set_y1(rayLine, targetLevel)
    line.set_y2(rayLine, targetLevel)

// Etiqueta con el texto "Hola Mundo" colocada ligeramente a la derecha del último bar
var label holaLabel = na
labelX = bar_index + 1
labelY = targetLevel
if na(holaLabel)
    holaLabel := label.new(x=labelX, y=labelY, xloc=xloc.bar_index, yloc=yloc.price, text="Hola Mundo", style=label.style_label_right, color=color.black, textcolor=color.white, size=size.small)
else
    label.set_xy(holaLabel, labelX, labelY)

// Opcional: dibujar un pequeño marcador con el nivel para debugging/visual
plot(targetLevel, title="Nivel 0.10% encima", color=color.new(color.yellow, 80), linewidth=1, transp=0)

// Documentación en línea (breve):
// - offsetPct: porcentaje configurado por el usuario (por defecto 0.10)
// - targetLevel: cálculo del nivel que es priceRef * (1 + offsetPct/100)
// - rayLine: línea que se extiende hacia la derecha y se actualiza cada barra
// - holaLabel: etiqueta con el mensaje "Hola Mundo" anclada al nivel
